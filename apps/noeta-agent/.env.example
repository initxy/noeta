# noeta-agent server configuration. Every key is optional; with everything
# left empty the server runs fully offline (mock LLM, dev-login, no sandbox).

# --- LLM gateway (OpenAI Responses-compatible) ---
# auto = use the gateway when base URL + key are set, otherwise the offline mock.
LLM_PROVIDER=auto
LLM_BASE_URL=
LLM_API_KEY=

# Optional secondary gateway for models tagged "gateway": "secondary" in
# models.json (multi-gateway routing).
SECONDARY_LLM_BASE_URL=
SECONDARY_LLM_API_KEY=

# --- auth ---
# Comma-separated usernames that get the admin console.
ADMIN_USERS=
# Change in any real deployment: signs the session cookie.
SESSION_SECRET=

# --- sandbox execution (requires Docker) ---
SANDBOX_ENABLED=false
