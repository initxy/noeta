# Copy into apps/noeta-agent/.env and fill in your gateway.
#
# LLM_BASE_URL is the gateway ROOT: the provider appends "/responses"
# (any OpenAI-Responses-compatible endpoint works). Auth uses the
# api-key header.
LLM_PROVIDER=auto
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=<your-api-key>

# Optional: a second Responses-compatible gateway (Bearer auth) for
# models tagged "gateway": "secondary" in models.json.
#SECONDARY_LLM_BASE_URL=
#SECONDARY_LLM_API_KEY=
